# Copy to `.env` and fill in. `.env` is gitignored.

# --- Postgres (matches compose.yml services) ---
DH_DB_HOST=dh-pg
DH_DB_PORT=5432
DH_DB_NAME=dh
DH_DB_USER=dh
DH_DB_PASSWORD=changeme-local-only

# --- Redis ---
DH_REDIS_URL=redis://dh-redis:6379/0
# Host-side mapping is 6381 (6380 is taken by moc-falkordb on this Dell).
# Workers/api inside the dh-net network use the internal 6379 above.

# --- Logging / runtime ---
# dev | prod
DH_LOG_LEVEL=INFO
DH_ENV=dev

# --- Discord (Phase 1+) ---
# Leave empty to keep the smoke-test command in 'disabled' mode.
DH_DISCORD_WEBHOOK_URL=

# --- Spend caps (Redis-enforced) ---
DH_LLM_DAILY_CALL_CAP=200
DH_WHOISJSON_DAILY_CAP=33
DH_WHOISFREAKS_DAILY_CAP=15
# 10 GB
DH_BIGQUERY_MAX_BYTES_BILLED=10737418240

# --- LLM transport ---
# 'codex_cli' (default) | 'anthropic_api' (future) | 'openai_api' (future) | 'stub' (tests)
DH_CLASSIFIER_TRANSPORT=codex_cli
DH_CODEX_BIN=codex

# --- BigQuery (Phase 0.5 spike + A2 worker) ---
# Path to a service-account JSON, OR leave empty if running on a host with default ADC.
GOOGLE_APPLICATION_CREDENTIALS=
DH_BIGQUERY_PROJECT=

# --- GitHub (Phase 0.5 spike + A2 worker) ---
# Personal access token with `public_repo` scope (read public READMEs at 5k/hr).
DH_GITHUB_TOKEN=

# --- WhoisJSON (RDAP fallback for non-RDAP TLDs) ---
DH_WHOISJSON_API_KEY=

# --- Premium-ceiling for digest gate ---
DH_PREMIUM_CEILING_USD=200
