# direnv config — auto-activates the uv venv when you `cd` into this dir.
# Run `direnv allow` once to enable.

# Use the project-managed venv from uv
if [ -f ".venv/bin/activate" ]; then
    source .venv/bin/activate
fi

# Load .env if present
if [ -f ".env" ]; then
    dotenv .env
fi

export DH_PROJECT_ROOT="$PWD"
